{
  "name": "auth-backend",
  "version": "1.0.0",
  "description": "Node.js TypeScript MySQL API with JWT authentication",
  "main": "dist/server.js",
  "scripts": {
   "build": "tsc && node copy-assets.js",
    "copy-files": "node -e \"require('fs').copyFileSync('.env', 'dist/.env'); require('fs').copyFileSync('config.json', 'dist/config.json')\"",
    "start": "node dist/server.js",
    "dev": "nodemon --exec ts-node server.ts"
  },
  "dependencies": {
    "@getbrevo/brevo": "^5.0.4",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.2",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "joi": "^18.2.1",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.6.5",
    "nodemailer": "^6.9.7",
    "sequelize": "^6.35.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/joi": "^17.2.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.41",
    "@types/nodemailer": "^6.4.23",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^9.0.8",
    "@types/yamljs": "^0.2.34",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2"
  }
}
