{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "**/*.ts",
    "_helpers/**/*.ts",
    "_middleware/**/*.ts",
    "accounts/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}